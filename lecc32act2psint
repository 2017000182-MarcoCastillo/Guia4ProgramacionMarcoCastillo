Algoritmo SignoZodiacal

    Definir dia, mes Como Entero
    Definir signo, horoscopo Como Cadena

    Escribir "Ingrese el dia de nacimiento:"
    Leer dia

    Escribir "Ingrese el mes de nacimiento (1-12):"
    Leer mes

    Si ((mes = 3 Y dia >= 21) O (mes = 4 Y dia <= 19)) Entonces
        signo <- "Aries"
        horoscopo <- "Hoy tendras mucha energia para cumplir tus metas."

    Sino
        Si ((mes = 4 Y dia >= 20) O (mes = 5 Y dia <= 20)) Entonces
            signo <- "Tauro"
            horoscopo <- "Recibiras una buena noticia muy pronto."

        Sino
            Si ((mes = 5 Y dia >= 21) O (mes = 6 Y dia <= 20)) Entonces
                signo <- "Geminis"
                horoscopo <- "Un nuevo reto te ayudara a crecer."

            Sino
                Si ((mes = 6 Y dia >= 21) O (mes = 7 Y dia <= 22)) Entonces
                    signo <- "Cancer"
                    horoscopo <- "Disfrutaras un momento especial con tu familia."

                Sino
                    Si ((mes = 7 Y dia >= 23) O (mes = 8 Y dia <= 22)) Entonces
                        signo <- "Leo"
                        horoscopo <- "Tu creatividad brillara el dia de hoy."

                    Sino
                        Si ((mes = 8 Y dia >= 23) O (mes = 9 Y dia <= 22)) Entonces
                            signo <- "Virgo"
                            horoscopo <- "La organizacion sera tu mejor aliada."

                        Sino
                            Si ((mes = 9 Y dia >= 23) O (mes = 10 Y dia <= 22)) Entonces
                                signo <- "Libra"
                                horoscopo <- "Encontraras equilibrio en tus decisiones."

                            Sino
                                Si ((mes = 10 Y dia >= 23) O (mes = 11 Y dia <= 21)) Entonces
                                    signo <- "Escorpio"
                                    horoscopo <- "Tu esfuerzo comenzara a dar resultados."

                                Sino
                                    Si ((mes = 11 Y dia >= 22) O (mes = 12 Y dia <= 21)) Entonces
                                        signo <- "Sagitario"
                                        horoscopo <- "Es un buen momento para aprender algo nuevo."

                                    Sino
                                        Si ((mes = 12 Y dia >= 22) O (mes = 1 Y dia <= 19)) Entonces
                                            signo <- "Capricornio"
                                            horoscopo <- "La disciplina te llevara al exito."

                                        Sino
                                            Si ((mes = 1 Y dia >= 20) O (mes = 2 Y dia <= 18)) Entonces
                                                signo <- "Acuario"
                                                horoscopo <- "Una gran idea llegara a tu mente."

                                            Sino
                                                signo <- "Piscis"
                                                horoscopo <- "Hoy sera un excelente dia para relajarte."
                                            FinSi
                                        FinSi
                                    FinSi
                                FinSi
                            FinSi
                        FinSi
                    FinSi
                FinSi
            FinSi
        FinSi
    FinSi

    Escribir "Tu signo zodiacal es: ", signo
    Escribir "Horoscopo: ", horoscopo

FinAlgoritmo
