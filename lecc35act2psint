Algoritmo CambioCajero

    Definir precio, pago, cambio Como Entero
    Definir billetes200, billetes50, monedas20, residuo Como Entero

    Escribir "Ingrese el precio del producto:"
    Leer precio

    Escribir "Ingrese la cantidad con la que paga el cliente:"
    Leer pago

    cambio <- pago - precio

    billetes200 <- cambio DIV 200
    residuo <- cambio MOD 200

    billetes50 <- residuo DIV 50
    residuo <- residuo MOD 50

    monedas20 <- residuo DIV 20

    Escribir "Cambio total: Q", cambio
    Escribir "Billetes de Q200: ", billetes200
    Escribir "Billetes de Q50: ", billetes50
    Escribir "Monedas de Q20: ", monedas20

FinAlgoritmo
