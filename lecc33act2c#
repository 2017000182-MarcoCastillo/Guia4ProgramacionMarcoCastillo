using System;

class Program
{
    static void Main()
    {
        string frase;

        Console.Write("Ingrese una frase: ");
        frase = Console.ReadLine();

        Console.Write("La frase invertida es: ");

        for (int i = frase.Length - 1; i >= 0; i--)
        {
            Console.Write(frase[i]);
        }

        Console.WriteLine();
        Console.ReadKey();
    }
}
